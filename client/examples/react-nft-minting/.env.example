# Fluid NFT Minting Demo Environment Variables

# Soroban RPC endpoint
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# NFT contract ID (deployed Soroban contract)
VITE_NFT_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4

# Fluid server URL
VITE_FLUID_SERVER_URL=https://testnet.fluid.dev

# Stellar network passphrase
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Stellar Expert URL
VITE_STELLAR_EXPERT_URL=https://stellar.expert/explorer/testnet

# Horizon API endpoint
VITE_HORIZON_URL=https://horizon-testnet.stellar.org
