{
  "name": "fluid-server-rust",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "fluid-server/src",
  "tags": ["scope:backend", "type:app", "lang:rust"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo build --release",
        "cwd": "fluid-server"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/Cargo.toml",
        "{workspaceRoot}/Cargo.toml"
      ],
      "outputs": ["{workspaceRoot}/target/release/fluid-server"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test",
        "cwd": "fluid-server"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/tests/**/*",
        "{projectRoot}/Cargo.toml"
      ]
    }
  }
}
