{
  "name": "admin-dashboard",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "admin-dashboard",
  "tags": ["scope:admin", "type:app", "lang:ts"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run build",
        "cwd": "admin-dashboard"
      },
      "cache": true,
      "inputs": ["production", "^production"],
      "outputs": ["{workspaceRoot}/admin-dashboard/.next"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run dev",
        "cwd": "admin-dashboard"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint",
        "cwd": "admin-dashboard"
      },
      "cache": true,
      "inputs": ["default"]
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run format:check",
        "cwd": "admin-dashboard"
      },
      "cache": true,
      "inputs": ["default"]
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run test:e2e",
        "cwd": "admin-dashboard"
      }
    }
  }
}
