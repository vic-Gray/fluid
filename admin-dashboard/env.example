# NextAuth.js Configuration
AUTH_SECRET=                  # Required: random 32+ char secret for JWT signing
ADMIN_EMAIL=                  # Required: admin login email address
ADMIN_PASSWORD_HASH=          # Required: bcrypt hash of admin password

# Generate AUTH_SECRET with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# Generate ADMIN_PASSWORD_HASH with (replace 'your-password' with actual password):
# node -e "const bcrypt = require('bcryptjs'); console.log(bcrypt.hashSync('your-password', 12));"

# Development URL (optional)
NEXTAUTH_URL=http://localhost:3001

# Fluid backend URL (for billing proxy)
FLUID_SERVER_URL=http://localhost:3000

# Admin token — must match FLUID_ADMIN_TOKEN on the server (used by the Connect Device dialog)
FLUID_ADMIN_TOKEN=
# Developer portal landing (public URLs — optional; defaults shown in lib/portal-links.ts)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DOCS_URL=https://docs.fluid.dev
NEXT_PUBLIC_GITHUB_URL=https://github.com/fluid-org/fluid
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/fluid

# Self-service tenant registration
# The server uses this to build the verification link sent in the confirmation email.
# Must be set to the public URL of this dashboard (e.g. https://dashboard.yourcompany.com).
# Also set REGISTRATION_VERIFY_BASE_URL to the same value in the server .env.
NEXTAUTH_URL=http://localhost:3001

# Discourse community forum integration
# Base URL of your Discourse instance (no trailing slash)
NEXT_PUBLIC_DISCOURSE_URL=https://community.fluid.dev
# Category ID to fetch topics from (find in Discourse admin → Categories)
NEXT_PUBLIC_DISCOURSE_CATEGORY_ID=1
# SSO secret — only required if enabling Discourse SSO login (leave blank to disable)
DISCOURSE_SSO_SECRET=

# Roadmap voting board
# HMAC-SHA256 secret used to sign short-lived SSO tokens for the roadmap board.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ROADMAP_SSO_SECRET=

# Sandbox environment
# Public URL of the Stellar Quickstart Horizon instance (shown in the sandbox panel)
NEXT_PUBLIC_SANDBOX_HORIZON_URL=http://localhost:8000
# Sandbox rate limit displayed in the dashboard UI
NEXT_PUBLIC_SANDBOX_RATE_LIMIT_MAX=10
