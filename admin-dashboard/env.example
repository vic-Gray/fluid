# NextAuth.js Configuration
AUTH_SECRET=                  # Required: random 32+ char secret for JWT signing
ADMIN_EMAIL=                  # Required: admin login email address
ADMIN_PASSWORD_HASH=          # Required: bcrypt hash of admin password


# Generate AUTH_SECRET with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# Generate ADMIN_PASSWORD_HASH with (replace 'your-password' with actual password):
# node -e "const bcrypt = require('bcryptjs'); console.log(bcrypt.hashSync('your-password', 12));"

# Development URL (optional)
NEXTAUTH_URL=http://localhost:3001

# Blocklist Configuration
BLOCKLIST_EXPIRY_SECONDS=3600
BLOCKLIST_MAX_REQUESTS=5
BLOCKLIST_TIME_WINDOW=10

# Fluid backend URL (for billing proxy)
FLUID_SERVER_URL=http://localhost:3000

# Admin token — must match FLUID_ADMIN_TOKEN on the server (used by the Connect Device dialog)
FLUID_ADMIN_TOKEN=

# Embedded AI support assistant
# Choose `openai`, `local`, or `mock` (for local verification/tests).
AI_SUPPORT_PROVIDER=openai
# Default examples: `gpt-4.1-mini` for OpenAI, `llama3.1` for a local OpenAI-compatible server.
AI_SUPPORT_MODEL=gpt-4.1-mini
# Required when AI_SUPPORT_PROVIDER=openai
OPENAI_API_KEY=
# Base URL for an OpenAI-compatible local model server such as Ollama or LM Studio.
AI_SUPPORT_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
# Optional bearer token for the local model server.
AI_SUPPORT_LOCAL_API_KEY=local

# ── CDN Edge Caching (Phase 14 — Performance) ────────────────────────────────
# Base URL of your CDN distribution (no trailing slash).
# When set, Next.js rewrites all /_next/static/ asset URLs and image src
# attributes to load from the CDN edge rather than the origin server.
# Cloudflare example:  https://cdn.yourdomain.com
# CloudFront example:  https://d1234abcd.cloudfront.net
# Leave empty in local development — assets are served from the local origin.
NEXT_PUBLIC_CDN_URL=

# Developer portal landing (public URLs — optional; defaults shown in lib/portal-links.ts)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DOCS_URL=https://docs.fluid.dev
NEXT_PUBLIC_GITHUB_URL=https://github.com/fluid-org/fluid
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/fluid

# Self-service tenant registration
# The server uses this to build the verification link sent in the confirmation email.
# Must be set to the public URL of this dashboard (e.g. https://dashboard.yourcompany.com).
# Also set REGISTRATION_VERIFY_BASE_URL to the same value in the server .env.
NEXTAUTH_URL=http://localhost:3001

# Discourse community forum integration
# Base URL of your Discourse instance (no trailing slash)
NEXT_PUBLIC_DISCOURSE_URL=https://community.fluid.dev
# Category ID to fetch topics from (find in Discourse admin → Categories)
NEXT_PUBLIC_DISCOURSE_CATEGORY_ID=1
# SSO secret — only required if enabling Discourse SSO login (leave blank to disable)
DISCOURSE_SSO_SECRET=

# Partner Certification
# Base URL used to generate embeddable badge verification links.
# Defaults to NEXT_PUBLIC_SITE_URL if not set.
# NEXT_PUBLIC_SITE_URL is already defined above and doubles as the partner badge base URL.

# Roadmap voting board
# HMAC-SHA256 secret used to sign short-lived SSO tokens for the roadmap board.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ROADMAP_SSO_SECRET=

# Sandbox environment
# Public URL of the Stellar Quickstart Horizon instance (shown in the sandbox panel)
NEXT_PUBLIC_SANDBOX_HORIZON_URL=http://localhost:8000
# Sandbox rate limit displayed in the dashboard UI
NEXT_PUBLIC_SANDBOX_RATE_LIMIT_MAX=10

# Referral Programme
# Bonus credited to the referrer (in stroops) when a referred user completes their first bump.
# Defaults to 1000 if not set.
REFERRAL_BONUS_STROOPS=1000

# ── Fluid Node Network Map (Issue #265) ──────────────────────────────────────
# Timeout in milliseconds for health-check pings sent to registered public nodes.
# Nodes that do not respond within this window are marked offline.
# Defaults to 5000 ms.
NODE_PING_TIMEOUT_MS=5000

# ── Playwright E2E (Issue #220) ──────────────────────────────────────────────
# Plain-text password for the E2E test admin user.
# Keep this ONLY in .env.local / GitHub Actions secrets — never commit.
ADMIN_PASSWORD=

# Override the base URL Playwright targets (default: http://127.0.0.1:3000).
# Set in CI if the dashboard runs on a different port or host.
PLAYWRIGHT_BASE_URL=

# ── Chromatic Visual Regression (Issue #222) ─────────────────────────────────
# Sign up at https://www.chromatic.com and create a project linked to this repo.
# Copy the project token from Chromatic → Manage → Configure and add it as a
# GitHub Actions secret named CHROMATIC_PROJECT_TOKEN.
CHROMATIC_PROJECT_TOKEN=
