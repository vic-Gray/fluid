// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Tenant {
  id                 String            @id @default(uuid())
  name               String
  dailyQuotaStroops  BigInt            @default(1000000) // 0.1 XLM default
  totalCredit        BigInt            @default(0) // Total purchased credit
  webhookUrl         String?
  apiKeys            ApiKey[]
  webhookDeliveries  WebhookDelivery[]
  payments           Payment[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model ApiKey {
  id                String   @id @default(uuid())
  key               String   @unique
  prefix            String
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  active            Boolean  @default(true)
  dailyQuotaStroops BigInt   @default(1000000) // 0.1 XLM default
  maxRequests       Int      @default(5)
  windowMs          Int      @default(60000)
  tier              String   @default("free") // free or pro
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model WebhookDelivery {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  url         String
  payload     Json
  status      String   @default("pending") // pending, success, failed
  retryCount  Int      @default(0)
  lastError   String?
  nextAttempt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([tenantId])
}

model Payment {
  id                String   @id @default(uuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stripeSessionId   String   @unique
  stripePaymentId   String?  @unique
  amountCents       Int
  creditStroops     BigInt
  status            String   @default("pending") // pending, completed, failed
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@index([stripeSessionId])
}

model SponsoredTransaction {
  id         String   @id @default(uuid())
  tenantId   String
  feeStroops BigInt
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
}
