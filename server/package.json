{
  "name": "fluid-server-ts",
  "version": "0.1.1",
  "description": "Fluid - Stellar fee sponsorship server (TypeScript)",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run native:build && tsc",
    "build:ts": "tsc",
    "lint": "echo \"No lint configured\"",
    "format:check": "echo \"No format check configured\"",
    "native:build": "napi build --release",
    "native:build:debug": "napi build",
    "benchmark:signing": "npm run native:build && ts-node src/benchmarks/signing.ts",
    "benchmark:migration": "ts-node src/benchmarks/migration.ts",
    "parity:rust": "npm run native:build && powershell -NoProfile -Command \"Get-Process fluid-server -ErrorAction SilentlyContinue | Stop-Process -Force; exit 0\" && cargo build -q --manifest-path ..\\fluid-server\\Cargo.toml && ts-node scripts/parityCheck.ts",
    "test:signer-pool": "npm run native:build && node --test -r ts-node/register src/signing/signerPool.test.ts",
    "grpc-engine": "cargo run --manifest-path Cargo.toml --bin grpc_engine",
    "test:grpc-mtls": "vitest run src/signing/grpcEngine.test.ts",
    "demo:horizon-failover": "node scripts/horizonFailoverDemo.mjs",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch",
    "test": "vitest",
    "audit:prisma-indexes": "ts-node src/services/prismaIndexAudit.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "docs": "typedoc"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "napi": {
    "name": "fluid_signer"
  },
  "keywords": [
    "stellar",
    "fee-bump",
    "gas-sponsorship"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@cosmjs/amino": "^0.38.1",
    "@cosmjs/encoding": "^0.38.1",
    "@cosmjs/proto-signing": "^0.38.1",
    "@cosmjs/stargate": "^0.38.1",
    "@libsql/client": "^0.17.2",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@prisma/config": "^7.6.0",
    "@solana/web3.js": "^1.98.4",
    "@stellar/stellar-sdk": "^11.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@wormhole-foundation/sdk": "^4.14.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.1",
    "cors": "^2.8.6",
    "decimal.js": "^10.6.0",
    "ethers": "^6.16.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "firebase-admin": "^13.7.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^4.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.1",
    "dotenv": "^17.3.1",
    "node-forge": "^1.3.1",
    "prisma": "^7.5.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
