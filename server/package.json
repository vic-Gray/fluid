{
  "name": "fluid-server-ts",
  "version": "0.1.0",
  "description": "Fluid - Stellar fee sponsorship server (TypeScript)",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run native:build && tsc",
    "build:ts": "tsc",
    "native:build": "napi build --release",
    "native:build:debug": "napi build",
    "benchmark:signing": "npm run native:build && ts-node src/benchmarks/signing.ts",
    "parity:rust": "npm run native:build && powershell -NoProfile -Command \"Get-Process fluid-server -ErrorAction SilentlyContinue | Stop-Process -Force; exit 0\" && cargo build -q --manifest-path ..\\fluid-server\\Cargo.toml && ts-node scripts/parityCheck.ts",
    "test:signer-pool": "npm run native:build && node --test -r ts-node/register src/signing/signerPool.test.ts",
    "demo:horizon-failover": "node scripts/horizonFailoverDemo.mjs",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch",
    "test": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "napi": {
    "name": "fluid_signer"
  },
  "keywords": [
    "stellar",
    "fee-bump",
    "gas-sponsorship"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@stellar/stellar-sdk": "^11.3.0",
    "better-sqlite3": "^12.8.0",
    "bullmq": "^5.71.1",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.1",
    "dotenv": "^17.3.1",
    "prisma": "^7.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.1"
  }
}
